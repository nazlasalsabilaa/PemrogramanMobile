<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#FAFAFA">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calculate Tip"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#CC000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/billBox"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="15dp"
        android:background="@drawable/bottom_line"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:text="100"
            android:textStyle="bold"
            android:gravity="center"
            android:textSize="10sp"
            android:textColor="#5D4037"
            android:background="@drawable/box_border"
            android:layout_marginEnd="10dp"/>

        <EditText
            android:id="@+id/etBillAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Bill Amount"
            android:inputType="numberDecimal"
            android:background="@null"
            android:textColorHint="#5D4037"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tipBox"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/bottom_line"
        app:layout_constraintTop_toBottomOf="@id/billBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="35dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tip Percentage"
            android:textSize="12sp"
            android:textColor="#5D4037"
            android:layout_marginStart="41dp"
            android:layout_marginBottom="5dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="35dp"
                android:layout_height="match_parent"
                android:text="%"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#5D4037"
                android:gravity="center"/>

            <Spinner
                android:id="@+id/spTipPercentage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:popupBackground="#F3E5F5"
                android:dropDownVerticalOffset="45dp"/>
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/txtRound"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Round up tip?"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#CC000000"
        app:layout_constraintTop_toBottomOf="@id/tipBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switchRound"
        android:layout_marginTop="35dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchRound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/txtRound"
        app:layout_constraintBottom_toBottomOf="@id/txtRound"
        app:layout_constraintEnd_toEndOf="parent"
        app:thumbTint="@color/switch_thumb"
        app:trackTint="@color/switch_track"/>

    <TextView
        android:id="@+id/tvTipAmount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tip Amount: $0.00"
        android:textSize="38sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/switchRound"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="35dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>